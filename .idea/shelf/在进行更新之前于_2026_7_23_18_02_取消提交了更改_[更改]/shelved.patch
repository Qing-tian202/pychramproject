diff --git a/http_test/API_test/pytest.ini b/http_test/API_test/pytest.ini
new file mode 100644
--- /dev/null	(date 1784282470346)
+++ b/http_test/API_test/pytest.ini	(date 1784282470346)
@@ -0,0 +1,28 @@
+[pytest]
+# 添加命令行参数
+addopts = -s -v --tb=short  --clean-alluredir
+# 文件搜索路径
+testpaths = ./case
+# 文件名称
+python_files = test*.py
+# 类名称
+python_classes = Test*
+# 方法名称
+python_functions = test*
+
+# 启用日志
+log_cli = false
+log_cli_level = INFO
+log_cli_format = %(asctime)s - %(levelname)s - %(message)s
+log_cli_date_format = %Y-%m-%d %H:%M:%S
+
+# 配置文件日志
+log_file_level = INFO
+log_file_format = %(asctime)s - %(name)s - %(levelname)s - %(filename)s:%(lineno)d - %(message)s
+log_file_date_format = %Y-%m-%d %H:%M:%S
+
+# 日志自动缩进
+log_auto_indent = true
+
+# 日志追加模式
+log_file_mode = a
\ No newline at end of file
