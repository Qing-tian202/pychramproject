{
    "type":"object",
    "properties":{
        "token":{
            "type":"string"
        },
        "adminBean":{
            "type":"object",
            "properties":{
                "uuid":{
                    "type":"string",
                    "pattern":"^[a-z0-9]{8}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{12}$"
                },
                "username":{
                    "type":"string"
                },
                "adminRole":{
                    "type":"string"
                },
                "adminStatus":{
                    "type":"string"
                },
                "adminDesc":{
                    "type":"null"
                }
            },
            "required": ["uuid","username","adminRole","adminStatus","adminDesc"]
        }
    },
    "required": ["token", "adminBean"]

}
